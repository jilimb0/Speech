{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "noEmit": true,
    "noPropertyAccessFromIndexSignature": false
  },
  "references": [{ "path": "../../packages/shared" }],
  "include": ["src/**/*"]
}
