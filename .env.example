# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# OpenAI (Whisper)
OPENAI_API_KEY=your_openai_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/speech_db

# API
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=https://your-miniapp-domain.com

# Web App
WEB_APP_URL=https://your-miniapp-domain.com

# Limits
FREE_DAILY_SESSION_LIMIT=2
MIN_AUDIO_DURATION_SEC=15
MAX_AUDIO_DURATION_SEC=90

# Optional: faster-whisper microservice (future)
# FASTER_WHISPER_URL=http://localhost:8001
